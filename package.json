{
  "name": "shopper-growth-copilot",
  "version": "1.0.0",
  "private": true,
  "description": "AI-native Mini CRM for retail marketing — Shopper Growth Copilot",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @scp/db generate",
    "db:push": "pnpm --filter @scp/db push",
    "db:migrate": "pnpm --filter @scp/db migrate",
    "db:migrate:deploy": "pnpm --filter @scp/db migrate:deploy",
    "db:seed": "pnpm --filter @scp/db seed",
    "db:studio": "pnpm --filter @scp/db studio",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "setup": "pnpm install && pnpm db:generate && pnpm db:push && pnpm db:seed"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
