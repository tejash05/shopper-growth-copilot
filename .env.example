# ─────────────────────────────────────────────────────────────
# Shopper Growth Copilot — environment configuration
# Copy to `.env` at the repo root for local development.
# Production: set these in Vercel (web) and Railway (services/plugins).
# Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
# Postgres (local: docker-compose.yml | prod: Railway Postgres)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://scp:scp@localhost:5432/shopper_growth_copilot?schema=public"

# ═══════════════════════════════════════════════════════════════
# Redis (local: docker-compose.yml | prod: Railway Redis)
# BullMQ broker — required by crm-api and channel-service
# ═══════════════════════════════════════════════════════════════
REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════════════════════════
# apps/web (Vercel)
# Browser + SSR reach the CRM API at this public URL
# ═══════════════════════════════════════════════════════════════
NEXT_PUBLIC_CRM_API_URL="http://localhost:4000"
# Optional SSR fallback (same as above in production)
CRM_API_URL="http://localhost:4000"

# ═══════════════════════════════════════════════════════════════
# apps/crm-api (Railway service)
# Railway injects PORT — apps bind to PORT automatically (see env.ts)
# ═══════════════════════════════════════════════════════════════
# Local only; Railway uses PORT instead
CRM_API_PORT=4000
# Public URL of channel-service (Railway)
CHANNEL_SERVICE_URL="http://localhost:4001"
# Comma-separated CORS origins — set to your Vercel URL in production
# Example: CORS_ORIGIN="https://your-app.vercel.app,https://your-app-*.vercel.app"
CORS_ORIGIN="http://localhost:3000"

# ═══════════════════════════════════════════════════════════════
# apps/channel-service (Railway service)
# Railway injects PORT — apps bind to PORT automatically (see env.ts)
# ═══════════════════════════════════════════════════════════════
# Local only; Railway uses PORT instead
CHANNEL_SERVICE_PORT=4001
# Public URL of crm-api (Railway) — used for signed lifecycle callbacks
CRM_API_URL="http://localhost:4000"

# ═══════════════════════════════════════════════════════════════
# Shared secret (crm-api + channel-service — MUST match)
# Sign/verify HMAC on channel callbacks. Rotate in production.
# ═══════════════════════════════════════════════════════════════
CHANNEL_CALLBACK_SECRET="dev-super-secret-rotate-me"

# ═══════════════════════════════════════════════════════════════
# OpenAI (@scp/ai via crm-api only)
# AI_PROVIDER: "mock" (deterministic demo, no key) | "openai"
# ═══════════════════════════════════════════════════════════════
AI_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ═══════════════════════════════════════════════════════════════
# General
# ═══════════════════════════════════════════════════════════════
NODE_ENV="development"
